{
    "editor.fontSize": 15,
    "editor.fontFamily": "Fira Code",
    "editor.tabSize": 2,
    "editor.fontLigatures": true,
    "workbench.colorTheme": "Visual Studio Light",
    "editor.trimAutoWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "explorer.openEditors.visible": 0,
    "editor.wordWrap": "on",
    "files.exclude": {
      "**/.git": true,
      "**/.svn": true,
      "**/.hg": true,
      "**/CVS": true,
      "**/.DS_Store": true,
      "**/tmp": true,
      "**/log": true,
      "**/node_modules": true,
      "**/coverage": true
    },
    "search.exclude": {
      "**/public/packs": true,
      "**/node_modules": true,
      "**/bower_components": true
    },
    "ruby.rubocop.executePath": "/Users/patrick/.rbenv/shims/",
    "typescript.check.npmIsInstalled": false,
    "sublimeTextKeymap.promptV3Features": true,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.snippetSuggestions": "top",
    "editor.formatOnPaste": true,
    "window.zoomLevel": 0,
    "files.associations": {
      "*.json": "jsonc"
    },
    "cSpell.userWords": [
      "aleksey",
      "authentification",
      "backend",
      "deployable",
      "elasticsearch",
      "gitlab",
      "instaffo",
      "jesper",
      "robocruiter",
      "rubocop",
      "uuid",
      "webpacker"
    ],
    "cSpell.enabledLanguageIds": [
      "asciidoc",
      "c",
      "cpp",
      "csharp",
      "css",
      "go",
      "handlebars",
      "html",
      "jade",
      "javascript",
      "javascriptreact",
      "json",
      "latex",
      "less",
      "markdown",
      "php",
      "plaintext",
      "pub",
      "python",
      "restructuredtext",
      "rust",
      "scss",
      "text",
      "typescript",
      "typescriptreact",
      "yml"
    ]
  }
